# ─── Database ──────────────────────────────────
DATABASE_URL=

# ─── NextAuth (added in a later feature) ─────────────
AUTH_SECRET=
# Canonical app origin. Drives email verify/reset links (getBaseUrl) and
# NextAuth callbacks. In production set this to https://devstash.xyz.
# Locally it can be left empty (falls back to the request host).
AUTH_URL=


# ─── GitHub OAuth (later) ────────────────────────────
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ─── Resend  ─────────────
RESEND_API_KEY=
# Sender address. Leave empty locally to use the Resend sandbox
# (onboarding@resend.dev). In production set a verified devstash.xyz sender,
# e.g. EMAIL_FROM="DevStash <noreply@devstash.xyz>" — required, the app throws
# in production if it's missing.
EMAIL_FROM=
# Defaults to enabled. Set to "false" only for relaxed local testing.
# Leave empty or set "true" in production.
EMAIL_VERIFICATION_ENABLED=

# ─── upstash  ─────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── cloudflare R2 storage  ─────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ─── OpenAI ──────────────────────────────────
OPENAI_API_KEY=

# ─── Stripe ──────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=
# Only needed if we ever embed Stripe Elements / Stripe.js in the browser.
# Our current Checkout integration is a server-side redirect, so this is unused.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
